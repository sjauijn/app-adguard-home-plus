#!/command/with-contenv bashio
# shellcheck shell=bash
# shellcheck disable=SC2207
# ==============================================================================
# AdGuard Home Plus
# Handles configuration
# ==============================================================================
#
# addon_config:rw mounts the addon config dir.
# Inside the container it is accessible at /homeassistant/addon_configs/<slug>/
# but HA also creates a symlink /config -> that directory.
# We use /config as the canonical path.
#
readonly CONFIG_DIR="/config"
readonly CONFIG="${CONFIG_DIR}/AdGuardHome.yaml"
readonly OLD_CONFIG="/data/adguard/AdGuardHome.yaml"
declare schema_version
declare -a interfaces
declare -a hosts
declare part
declare fd
declare a2

# Ensure runtime data directory exists
mkdir -p /data/adguard

if ! bashio::fs.file_exists "${CONFIG}"; then
    if bashio::fs.file_exists "${OLD_CONFIG}"; then
        bashio::log.info "Migrating AdGuardHome.yaml from /data/adguard/ to ${CONFIG_DIR}/"
        cp "${OLD_CONFIG}" "${CONFIG}"
        mv "${OLD_CONFIG}" "${OLD_CONFIG}.bak"
        bashio::log.info "Old config backed up as AdGuardHome.yaml.bak in /data/adguard/"
    else
        bashio::log.info "Creating default AdGuardHome.yaml in ${CONFIG_DIR}/"
        cp /etc/adguard/AdGuardHome.yaml "${CONFIG}"
    fi
fi

port=$(bashio::addon.port "53/udp") \
  yq e --inplace '.dns.port = env(port)' "${CONFIG}" \
    || bashio::exit.nok 'Failed updating AdGuardHome DNS port'

schema_version=$(yq e '.schema_version // ""' "${CONFIG}")
if bashio::var.has_value "${schema_version+}"; then
    if (( schema_version == 7 )); then
        yq --inplace e 'del(.dns.bind_host)' "${CONFIG}"
        yq --inplace e '.schema_version = 8' "${CONFIG}"
    fi

    if (( schema_version < 7 )); then
        yq --inplace e '.dns.bind_host = "127.0.0.1"' "${CONFIG}"
        bashio::warning
        bashio::warning "AdGuard Home needs to update its configuration schema"
        bashio::warning "you might need to restart the app once more to complete"
        bashio::warning "the upgrade process."
        bashio::warning
        bashio::exit.ok
    fi
else
    yq --inplace e '.dns.bind_host = "127.0.0.1"' "${CONFIG}"
fi

interfaces+=($(bashio::network.interfaces))
for interface in "${interfaces[@]}"; do
    for host in $(bashio::network.ipv4_address "${interface}"); do
        hosts+=("${host%/*}")
    done
    for host in $(bashio::network.ipv6_address "${interface}"); do
        part="${host%%:*}"
        fd=$(( (0x$part) / 256 ))
        a2=$(( (0x$part) % 256 ))
        if (( (fd == 254) && ( (a2 & 192) == 128) )); then
            hosts+=("${host%/*}%${interface}")
        else
            hosts+=("${host%/*}")
        fi
    done
done
hosts+=($(bashio::addon.ip_address))
hosts+=("127.0.0.1")
hosts+=("::1")

yq --inplace e '.dns.bind_hosts = []' "${CONFIG}"
for host in "${hosts[@]}"; do
    if ! bashio::var.has_value "${host}"; then
        continue
    fi
    if [[ "${host}" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        part="${host%%.*}"
        if (( part == 169 )); then
            continue
        fi
    fi
    host="${host}" yq --inplace e \
      '.dns.bind_hosts += [env(host)]' "${CONFIG}" \
        || bashio::exit.nok 'Failed updating AdGuardHome host'
done
